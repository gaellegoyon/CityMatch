# ════════════════════════════════════════════════════════════
#  CityMatch — Variables d'environnement
#  Copiez ce fichier en .env et remplissez vos clés API
# ════════════════════════════════════════════════════════════

# ─── LLM Principal : Google AI Studio (GRATUIT) ──────────────
# Obtenir une clé : https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_google_api_key_here

# ─── LLM Fallback : Groq (GRATUIT) ───────────────────────────
# Obtenir une clé : https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# ─── Recherche Web : Tavily (GRATUIT jusqu'à 1000 req/mois) ──
# Obtenir une clé : https://app.tavily.com
TAVILY_API_KEY=your_tavily_api_key_here

# ─── Configuration Base de Données ───────────────────────────
DATABASE_URL=sqlite:///./db/cities.db

# ─── Configuration ChromaDB (RAG) ────────────────────────────
CHROMA_PERSIST_DIR=./vectorstore

# ─── Modèles ─────────────────────────────────────────────────
# Gemini 2.0 Flash (recommandé — rapide et gratuit)
PRIMARY_MODEL=gemini-2.0-flash-exp
# Fallback Groq
FALLBACK_MODEL=llama-3.3-70b-versatile

# ─── Paramètres Application ──────────────────────────────────
APP_NAME=CityMatch
APP_VERSION=1.0.0
LOG_LEVEL=INFO
MAX_CITIES_IN_REPORT=10
